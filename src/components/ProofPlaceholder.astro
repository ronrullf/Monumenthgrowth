---
interface Props {
  label: string;
  hint: string;
}
const { label, hint } = Astro.props;
---
<div class="rounded-card border border-dashed border-border bg-card/50 p-6 text-center">
  <span class="eyebrow text-muted-foreground">{label}</span>
  <p class="mt-2 text-sm text-muted-foreground">{hint}</p>
</div>
