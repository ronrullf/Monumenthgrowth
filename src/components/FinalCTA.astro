---
import Section from './Section.astro';
import WhatsAppButton from './WhatsAppButton.astro';
import { MESSAGES } from '../lib/whatsapp';
---
<Section id="final-cta" tone="charcoal" ariaLabelledby="final-cta-heading">
  <div class="max-w-[720px] mx-auto text-center reveal">
    <h2 id="final-cta-heading" class="text-primary-foreground">
      Your next client is already on your camera roll.
    </h2>
    <p class="mt-6 text-lg leading-relaxed text-primary-foreground">
      That footage is doing nothing right now. Hand it over. Spend 1–2 hours a month.
      Get booked jobs instead.
    </p>
    <div class="mt-10 flex justify-center">
      <WhatsAppButton
        message={MESSAGES.finalCta}
        label="Get in touch"
        variant="large"
      />
    </div>
  </div>
</Section>
