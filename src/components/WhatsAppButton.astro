---
import { waLink } from '../lib/whatsapp';

interface Props {
  message: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'large';
  iconOnly?: boolean;
  class?: string;
}
const { message, label, variant = 'primary', iconOnly = false, class: className = '' } =
  Astro.props;

const base =
  'inline-flex items-center justify-center gap-2.5 rounded font-semibold transition-all duration-[180ms] ease-standard cta-focus min-h-[44px]';

// Monochrome system: ink bg + cream text gives ~13:1 contrast, no size workaround needed.
// "large" is reserved for the charcoal Final CTA band — inverted (cream bg, ink text) so
// it pops by value against the dark section instead of introducing a second hue.
const variantClass =
  variant === 'primary'
    ? 'bg-cta text-cta-foreground px-6 py-3.5 text-base hover:bg-cta-hover hover:shadow-md active:translate-y-px'
    : variant === 'large'
    ? 'bg-card text-foreground px-8 py-4 text-lg hover:bg-background hover:shadow-lg active:translate-y-px w-full sm:w-auto'
    : 'bg-transparent border border-primary text-primary px-6 py-3.5 text-base hover:bg-primary hover:text-primary-foreground active:translate-y-px';
---
<a
  href={waLink(message)}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${label} — opens WhatsApp`}
  class:list={[base, variantClass, className]}
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.226 1.36.194 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"></path>
    <path d="M12.004 2.003c-5.514 0-9.997 4.483-9.997 9.997 0 1.762.464 3.484 1.346 4.997L2 22l5.13-1.345a9.955 9.955 0 0 0 4.874 1.242h.004c5.514 0 9.997-4.483 9.997-9.997 0-2.67-1.04-5.178-2.929-7.067a9.933 9.933 0 0 0-7.068-2.83zm0 18.184a8.176 8.176 0 0 1-4.166-1.14l-.299-.177-3.045.799.812-2.968-.194-.305a8.19 8.19 0 0 1-1.259-4.366c0-4.523 3.68-8.202 8.203-8.202a8.146 8.146 0 0 1 5.8 2.403 8.146 8.146 0 0 1 2.399 5.8c0 4.523-3.68 8.156-8.251 8.156z"></path>
  </svg>
  {!iconOnly && <span>{label}</span>}
</a>
