---
interface Props {
  id: string;
  tone?: 'canvas' | 'card' | 'charcoal';
  ariaLabelledby?: string;
  class?: string;
}
const { id, tone = 'canvas', ariaLabelledby, class: className = '' } = Astro.props;

// Translucent, not opaque: the fixed .bg-aurora layer behind the page drifts through every
// section at a different tint. Arbitrary rgba values, not bg-*/NN modifiers — Tailwind can't
// apply an opacity modifier through a CSS-variable-backed color (see WhatsAppButton/Header fix).
const toneClass =
  tone === 'card'
    ? 'bg-[rgba(244,239,228,0.86)]'
    : tone === 'charcoal'
    ? 'bg-[rgba(46,46,46,0.95)]'
    : 'bg-[rgba(233,228,216,0.88)]';
---
<section
  id={id}
  aria-labelledby={ariaLabelledby}
  class:list={[toneClass, 'py-16 md:py-24', className]}
>
  <div class="max-w-container mx-auto px-6 md:px-8">
    <slot />
  </div>
</section>
