---
import Section from './Section.astro';
import Eyebrow from './Eyebrow.astro';
import LayerPanel from './LayerPanel.astro';
import WhatsAppButton from './WhatsAppButton.astro';
import { MESSAGES } from '../lib/whatsapp';
---
<Section id="hero" tone="canvas" class="pt-8 md:pt-12">
  <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
    <div class="lg:col-span-7 reveal">
      <Eyebrow text="ATTENTION LAYER + CONVERSION LAYER" />
      <h1 id="hero-heading" class="mt-4">
        Book more <span class="text-cta-text">$20K+</span> kitchen &amp; bath remodels from social media
        — on 1–2 hours a month.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-foreground max-w-xl">
        Monumenth Growth builds your attention layer and your conversion layer, so your raw
        footage turns into content, content turns into leads, and leads turn into booked jobs.
      </p>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground max-w-xl">
        You film the work. We do the rest — short-form content, a website wired to WhatsApp, and
        follow-ups that don't let leads go cold. Built specifically for remodeling contractors.
      </p>
      <div class="mt-8">
        <WhatsAppButton message={MESSAGES.hero} label="Get in touch" variant="primary" />
      </div>
      <p class="mt-4 text-sm text-muted-foreground">
        No forms. No email chains. One WhatsApp conversation.
      </p>
    </div>

    <div class="lg:col-span-5 reveal" style="transition-delay: 120ms;">
      <LayerPanel elevation="lg" class="max-w-md mx-auto lg:mx-0">
        <div class="aspect-[4/5] flex items-center justify-center p-8">
          <div class="flex flex-col items-center gap-4 text-muted-foreground">
            <span
              class="flex h-16 w-16 items-center justify-center rounded-full bg-muted"
              aria-hidden="true"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
            <span class="text-sm text-center">Your raw footage goes here</span>
          </div>
        </div>
      </LayerPanel>
    </div>
  </div>
</Section>
