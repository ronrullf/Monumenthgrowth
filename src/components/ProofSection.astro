---
import Section from './Section.astro';
import Eyebrow from './Eyebrow.astro';
import ProofPlaceholder from './ProofPlaceholder.astro';
import WhatsAppButton from './WhatsAppButton.astro';
import { MESSAGES } from '../lib/whatsapp';
---
<Section id="proof" tone="card" ariaLabelledby="proof-heading">
  <div class="max-w-[720px] mx-auto text-center reveal">
    <Eyebrow text="BUILT FOR ONE SECTOR" />
    <h2 id="proof-heading" class="mt-4">Built for one sector, not everyone.</h2>
    <p class="mt-6 text-lg leading-relaxed text-foreground">
      No dentists. No gyms. No generic "small business marketing."
      Just kitchen &amp; bath remodelers. The content sounds like your trade. The funnel is built
      around how remodels get booked.
    </p>
  </div>

  {/* [NEEDS PROOF — internal] Swap for real jobs-booked/views numbers and a named
      contractor quote as soon as they exist. Copy below is honest as written — no
      numbers are implied or fabricated — but replace it the moment real proof lands. */}
  <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-3xl mx-auto reveal">
    <ProofPlaceholder
      label="Results"
      hint="Case studies and real numbers will be added here as projects complete."
    />
    <ProofPlaceholder
      label="Testimonials"
      hint="Contractor reviews will be featured here as we complete work together."
    />
  </div>

  <div class="mt-10 flex justify-center reveal">
    <WhatsAppButton message={MESSAGES.proof} label="Get in touch" variant="primary" />
  </div>
</Section>
